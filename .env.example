# VM access — copy to .env and fill in values
VM_HOST=192.168.1.X  # LAN IP accessible via Tailscale subnet route
VM_USER=sysadmin
SSH_PORT=22          # optional, defaults to 22

# GitHub runner
RUNNER_SCOPE=repo        # "repo" = single repo, "org" = all repos in org
GITHUB_REPO=owner/repo   # required when RUNNER_SCOPE=repo
# GITHUB_ORG=myorg       # required when RUNNER_SCOPE=org
RUNNER_COUNT=2           # runners to register (1 per 2 vCPU recommended)
# GITHUB_TOKEN=ghp_...  # PAT with repo scope (classic) or Administration:write (fine-grained)
                         # can also be set in your shell env instead of here
